generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum UserType {
  HOMEOWNER
  SME
}

enum JobStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  PAID
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String    @id @default(uuid())
  phoneNumber   String    @unique
  role          Role?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workerProfile    WorkerProfile?
  customerProfile  CustomerProfile?
}

model WorkerProfile {
  id            String             @id @default(uuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id])
  
  trade         String[]
  district      String
  baseRate      Decimal?
  experience    String?
  
  status        VerificationStatus @default(UNVERIFIED)
  nicUrl        String?
  selfieUrl     String?
  certificates  String[]
  
  quotes        Quote[]
  reviews       Review[]
  
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model CustomerProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  
  type          UserType  @default(HOMEOWNER)
  district      String?
  
  jobs          Job[]
  reviews       Review[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Job {
  id            String      @id @default(uuid())
  customerId    String
  customer      CustomerProfile @relation(fields: [customerId], references: [id])
  
  trade         String
  description   String
  budget        Decimal?
  district      String
  location      String?     // Can be lat/long string or address
  
  status        JobStatus   @default(OPEN)
  
  quotes        Quote[]
  milestones    Milestone[]
  review        Review?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Quote {
  id            String      @id @default(uuid())
  jobId         String
  job           Job         @relation(fields: [jobId], references: [id])
  
  workerId      String
  worker        WorkerProfile @relation(fields: [workerId], references: [id])
  
  amount        Decimal
  description   String?
  status        QuoteStatus @default(PENDING)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([jobId, workerId])
}

model Milestone {
  id            String          @id @default(uuid())
  jobId         String
  job           Job             @relation(fields: [jobId], references: [id])
  
  title         String
  amount        Decimal
  status        MilestoneStatus @default(PENDING)
  proofUrl      String?
  order         Int
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Review {
  id            String          @id @default(uuid())
  jobId         String          @unique
  job           Job             @relation(fields: [jobId], references: [id])
  
  workerId      String
  worker        WorkerProfile   @relation(fields: [workerId], references: [id])
  
  customerId    String
  customer      CustomerProfile @relation(fields: [customerId], references: [id])
  
  rating        Int
  comment       String?
  
  createdAt     DateTime        @default(now())
}
